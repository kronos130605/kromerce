# Configuración para Render.com
APP_NAME=Kromerce
APP_ENV=production
APP_KEY=base64:Nybd2dqqU15PIehyV0CoGyM4gal2sMSQPCg0Z27SVfg=
APP_DEBUG=false
APP_URL=https://kromerce.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# PostgreSQL para Render.com
DB_CONNECTION=pgsql
DATABASE_URL=postgresql://kromerce_user:gOPvWdm0bBDH5vexiY0WiFBibRSrtmX3@dpg-d6eubok50q8c73aeae6g-a/kromerce

# Sesión optimizada para producción
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.kromerce.onrender.com
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=<HOST_DE_REDIS_SI_LO_CREAS>
REDIS_PASSWORD=<PASSWORD_DE_REDIS>
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=https://kromerce.onrender.com/api
